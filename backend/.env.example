PORT=4000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
TELEMETRY_IP_SALT=replace-with-a-separate-long-random-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/empower_recovery
# Comma-separated list of frontend origins allowed to call this API.
# Defaults to localhost:5173 + the production Vercel URL if unset.
ALLOWED_ORIGINS=http://localhost:5173,https://empower-recovery.vercel.app
