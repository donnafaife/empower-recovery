generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leads     Lead[]
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model Lead {
  id           String   @id @default(cuid())
  fullName     String
  email        String
  phone        String?
  message      String?
  source       String?
  status       String   @default("new")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assignedToId String?
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])
}
